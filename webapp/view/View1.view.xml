<mvc:View
  controllerName="project7.controller.View1"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Page title="Orders Dashboard">
    <content>

      <HBox width="100%" alignItems="Center" class="sapUiSmallMargin">

 
        <SearchField
          id="searchField"
          width="250px"
          placeholder="Search Orders"
          value="{filters>/search}"
          liveChange="onSearch"
        />

     
        <HBox class="sapUiSmallMarginBegin" alignItems="Center">
          <core:Icon src="sap-icon://status-positive" class="sapUiTinyMarginEnd"/>
          <ComboBox
            id="statusFilter"
            width="200px"
            selectedKey="{filters>/status}"
            change="onFilterChange">

            <items>
              <core:Item key="" text="All Status"/>
              <core:Item key="New" text="New"/>
              <core:Item key="Pending" text="Pending"/>
              <core:Item key="Shipped" text="Shipped"/>
            </items>
          </ComboBox>
        </HBox>


        <HBox class="sapUiSmallMarginBegin" alignItems="Center">
          <core:Icon src="sap-icon://world" class="sapUiTinyMarginEnd"/>
          <ComboBox
            id="countryFilter"
            width="200px"
            selectedKey="{filters>/country}"
            change="onFilterChange">

            <items>
              <core:Item key="" text="All Countries"/>
              <core:Item key="India" text="India"/>
              <core:Item key="USA" text="USA"/>
              <core:Item key="UK" text="UK"/>
              <core:Item key="Germany" text="Germany"/>
              <core:Item key="Canada" text="Canada"/>
            </items>
          </ComboBox>
        </HBox>

    
        <HBox class="sapUiSmallMarginBegin" alignItems="Center">
          <core:Icon src="sap-icon://money-bills" class="sapUiTinyMarginEnd"/>
          <ComboBox
            id="amountFilter"
            width="200px"
            selectedKey="{filters>/amount}"
            change="onFilterChange">

            <items>
              <core:Item key="" text="All Amounts"/>
              <core:Item key="low" text="&lt; 500"/>
              <core:Item key="mid" text="500 - 1000"/>
              <core:Item key="high" text="&gt; 1000"/>
            </items>
          </ComboBox>
        </HBox>


          <Button
          text="Search"
          press="onSearchPress"
          class="sapUiSmallMarginBegin"/>

          <Button
          text="Reset"
          press="onReset"
          class="sapUiSmallMarginBegin"/>

    <Button
        icon="sap-icon://palette"
        tooltip="Change Theme"
        press="onThemeToggle"
        class="sapUiTinyMarginBegin"
        align="right"/>

      </HBox>


      <Table
        id="orderTable"
        items="{/Orders}"
        mode="SingleSelectMaster"
        selectionChange="onSelect">

        <columns>
          <Column><Text text="Order ID"/></Column>
          <Column><Text text="Customer"/></Column>
          <Column><Text text="Country"/></Column>
          <Column><Text text="Amount"/></Column>
          <Column><Text text="Status"/></Column>
        </columns>

        <items>
          <ColumnListItem type="Navigation">
            <cells>
              <Text text="{OrderID}"/>
              <Text text="{Customer}"/>
              <Text text="{Country}"/>
              <Text text="{Amount}"/>
              <Text text="{Status}"/>
            </cells>
          </ColumnListItem>
        </items>

      </Table>

    </content>
  </Page>
</mvc:View>